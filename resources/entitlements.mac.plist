<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Enable hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory for V8 -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Disable library validation for native modules -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Network access for backend communication -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Network server for local backend -->
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- File access for user data -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Access to application support directory -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    
    <!-- Accessibility for keyboard shortcuts (optional) -->
    <!-- <key>com.apple.security.automation.apple-events</key>
    <true/> -->
</dict>
</plist>
